.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Keep optional VS Code recommendations if needed later
# !.vscode/extensions.json

# -------------------------
# .NET / ASP.NET Core
# -------------------------
bin/
obj/
[Bb]in/
[Oo]bj/

*.dll
*.exe
*.pdb
*.cache
*.log

# Rider / ReSharper
_ReSharper*/
*.DotSettings.user

# Visual Studio
.vs/

# Test results
TestResults/
coverage/
coverage.cobertura.xml
*.trx

# Publish output
publish/
out/

# -------------------------
# ASP.NET local settings
# -------------------------
appsettings.Local.json
appsettings.Production.json
appsettings.Staging.json

# IMPORTANT:
# We keep appsettings.Development.json allowed only if it has no secrets.
# If you accidentally put secrets inside it, remove them before commit.

